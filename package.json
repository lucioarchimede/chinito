{
  "name": "ecomdash-v2",
  "version": "1.0.0",
  "description": "EcomDash V2 - Dashboard de Ecommerce",
  "scripts": {
    "dev:server": "cd server && npm run dev",
    "dev:client": "cd client && npm run dev",
    "install:all": "npm install && cd server && npm install && cd ../client && npm install",
    "db:schema": "cd server && node -e \"require('./db/index').query(require('fs').readFileSync('./db/schema.sql','utf8')).then(()=>process.exit(0)).catch(e=>{console.error(e);process.exit(1)})\"",
    "db:seed": "cd server && node db/seed.js",
    "build:client": "cd client && npm run build"
  }
}
