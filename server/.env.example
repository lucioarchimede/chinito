# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/ecomdash

# ── Auth ──────────────────────────────────────────────────────────────────────
JWT_SECRET=your-super-secret-jwt-key-min-32-chars

# ── Encryption (for storing API tokens in DB) ─────────────────────────────────
# Must be at least 32 characters. Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=change-this-to-a-random-32+-char-secret

# ── CORS / URLs ───────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:5173
BACKEND_URL=http://localhost:3001

# ── Tiendanube Integration ────────────────────────────────────────────────────
# Create your app at: https://partners.tiendanube.com
# Set the OAuth redirect URI to: http://localhost:3001/api/integrations/tiendanube/callback
TIENDANUBE_CLIENT_ID=
TIENDANUBE_CLIENT_SECRET=

# ── Shopify Integration ───────────────────────────────────────────────────────
# Create your app at: https://partners.shopify.com
# Set the OAuth redirect URI to: http://localhost:3001/api/integrations/shopify/callback
# Required scopes: read_products,write_products,read_orders,read_inventory,write_inventory
SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=
SHOPIFY_REDIRECT_URI=http://localhost:3001/api/integrations/shopify/callback

# ── Environment ───────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3001
